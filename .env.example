# =============================================================================
# Copy this file to .env and fill in your values. Do not commit .env.
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required for API when using Docker or Postgres)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=rent_automation
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Password reset & frontend (forgot-password emails)
# Set FRONTEND_URL to the public URL of your frontend so reset links work.
# -----------------------------------------------------------------------------
FRONTEND_URL=https://app.yourdomain.com

# -----------------------------------------------------------------------------
# Email (SMTP) – required for sending password-reset links by email
# If not set, reset links are only printed to the server log (dev only).
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# Optional: sender shown in password-reset emails
EMAILS_FROM_EMAIL=noreply@yourdomain.com
EMAILS_FROM_NAME=RentFlow Automation
